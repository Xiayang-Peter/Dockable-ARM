<Window x:Class="Dockable.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Dockable.Localization"
        Title="{loc:Loc Window_DockPreferences}"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        SizeToContent="Height"
        Width="520"
        MinHeight="240"
        Background="#EDEDED"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Ideal"
        FontFamily="Segoe UI"
        Foreground="#1D1D1F">

    <Window.Resources>
        <!-- macOS-style toggle switch -->
        <Style x:Key="MacSwitch" TargetType="ToggleButton">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Track" CornerRadius="11">
                            <Border.Background>
                                <!-- Explicit (mutable) brush so its Color can be animated. -->
                                <SolidColorBrush x:Name="TrackBrush" Color="#E9E9EA" />
                            </Border.Background>
                            <!-- The knob rests at the left and slides right (via TranslateTransform) when on. -->
                            <Ellipse x:Name="Knob" Width="18" Height="18" Fill="White"
                                     HorizontalAlignment="Left" Margin="2,0,0,0">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform x:Name="KnobShift" X="0" />
                                </Ellipse.RenderTransform>
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="3" ShadowDepth="0.5" Opacity="0.35" Color="#000000" />
                                </Ellipse.Effect>
                            </Ellipse>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <!-- Travel = track(38) - knob(18) - margins(2+2) = 16. -->
                                            <DoubleAnimation Storyboard.TargetName="KnobShift" Storyboard.TargetProperty="X"
                                                             To="16" Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <ColorAnimation Storyboard.TargetName="TrackBrush" Storyboard.TargetProperty="Color"
                                                            To="#0A84FF" Duration="0:0:0.18" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="KnobShift" Storyboard.TargetProperty="X"
                                                             To="0" Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <ColorAnimation Storyboard.TargetName="TrackBrush" Storyboard.TargetProperty="Color"
                                                            To="#E9E9EA" Duration="0:0:0.18" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- macOS-style slider: thin gray track + round white thumb. Tick marks render only when
             TickPlacement is set (e.g. the Effect Speed slider's 5 positions). -->
        <Style x:Key="MacSlider" TargetType="Slider">
            <Setter Property="MinHeight" Value="22" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsMoveToPointEnabled" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <!-- Full width so the first/last ticks sit at the very ends of the slider. -->
                            <TickBar x:Name="TopTick" Grid.Row="0" Placement="Top" Height="4" Fill="#B6B6BB"
                                     SnapsToDevicePixels="True" Visibility="Collapsed" Margin="0,0,0,3"
                                     Minimum="{TemplateBinding Minimum}" Maximum="{TemplateBinding Maximum}"
                                     TickFrequency="{TemplateBinding TickFrequency}" />
                            <Grid Grid.Row="1" VerticalAlignment="Center">
                                <Border Height="4" CornerRadius="2" Background="#D6D6DA" VerticalAlignment="Center" />
                                <Track x:Name="PART_Track">
                                    <Track.Thumb>
                                        <Thumb>
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Ellipse Width="20" Height="20" Fill="White"
                                                             Stroke="#22000000" StrokeThickness="0.5">
                                                        <Ellipse.Effect>
                                                            <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.25" Color="#000000" />
                                                        </Ellipse.Effect>
                                                    </Ellipse>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                            <TickBar x:Name="BottomTick" Grid.Row="2" Placement="Bottom" Height="4" Fill="#B6B6BB"
                                     SnapsToDevicePixels="True" Visibility="Collapsed" Margin="0,3,0,0"
                                     Minimum="{TemplateBinding Minimum}" Maximum="{TemplateBinding Maximum}"
                                     TickFrequency="{TemplateBinding TickFrequency}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="TickPlacement" Value="TopLeft">
                                <Setter TargetName="TopTick" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="TickPlacement" Value="BottomRight">
                                <Setter TargetName="BottomTick" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="TickPlacement" Value="Both">
                                <Setter TargetName="TopTick" Property="Visibility" Value="Visible" />
                                <Setter TargetName="BottomTick" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- macOS-style pop-up button (ComboBox) -->
        <Style x:Key="MacPopupItem" TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="4"
                                Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0A84FF" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MacPopup" TargetType="ComboBox">
            <Setter Property="Height" Value="26" />
            <Setter Property="MinWidth" Value="130" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#1D1D1F" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource MacPopupItem}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="White" CornerRadius="6"
                                                BorderBrush="#22000000" BorderThickness="1">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="2" ShadowDepth="0.5" Opacity="0.12" Color="#000000" />
                                            </Border.Effect>
                                            <Path HorizontalAlignment="Right" VerticalAlignment="Center"
                                                  Margin="0,0,9,0" Stroke="#7A7A7E" StrokeThickness="1.3"
                                                  Data="M 0,3.5 L 3.5,0.5 L 7,3.5  M 0,7.5 L 3.5,10.5 L 7,7.5" />
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="11,0,26,0" VerticalAlignment="Center"
                                              HorizontalAlignment="Left" IsHitTestVisible="False" />
                            <Popup IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom" AllowsTransparency="True" PopupAnimation="Fade"
                                   Focusable="False">
                                <Border Background="White" CornerRadius="6" Margin="0,4,0,4"
                                        BorderBrush="#22000000" BorderThickness="1"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.22" Color="#000000" />
                                    </Border.Effect>
                                    <ItemsPresenter Margin="3" />
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Shared text styles -->
        <Style x:Key="RowLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#1D1D1F" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="Caption" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#8A8A8E" />
        </Style>
        <Style x:Key="GroupLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1D1D1F" />
        </Style>
    </Window.Resources>

    <ScrollViewer x:Name="PrefsScroll" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Focusable="False">
    <StackPanel Margin="20">
        <!-- System section (language + login) -->
        <TextBlock Text="{loc:Loc Section_System}" FontSize="15" FontWeight="SemiBold" Foreground="#1D1D1F" Margin="2,0,0,8" />
        <Border Background="White" CornerRadius="10" Margin="0,0,0,18">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.12" Color="#000000" />
            </Border.Effect>
            <StackPanel Margin="16,0,16,8">
                <!-- Language: native names; selection maps to a culture code in code-behind. -->
                <Grid Height="44">
                    <TextBlock Text="{loc:Loc Row_Language}" Style="{StaticResource RowLabel}" HorizontalAlignment="Left" />
                    <ComboBox x:Name="LanguageCombo" Style="{StaticResource MacPopup}" HorizontalAlignment="Right"
                              VerticalAlignment="Center" SelectionChanged="LanguageCombo_SelectionChanged" />
                </Grid>
                <Border Height="1" Background="#E3E3E3" Margin="0,0,0,0" />
                <Grid Height="44">
                    <TextBlock Text="{loc:Loc Row_OpenAtLogin}" Style="{StaticResource RowLabel}" HorizontalAlignment="Left" />
                    <ToggleButton x:Name="OpenAtLoginSwitch" Style="{StaticResource MacSwitch}" HorizontalAlignment="Right"
                                  VerticalAlignment="Center" Click="OpenAtLoginSwitch_Click" />
                </Grid>
                <!-- Link to the Windows "Startup Apps" settings page (opens in a new window). -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Cursor="Hand"
                            Background="Transparent" MouseLeftButtonUp="StartupApps_Click" Margin="0,0,0,4">
                    <TextBlock Text="{loc:Loc Link_StartupApps}" Foreground="#0A84FF" FontSize="12"
                               TextDecorations="Underline" VerticalAlignment="Center" />
                    <TextBlock Text="&#x2197;" Foreground="#0A84FF" FontSize="12"
                               Margin="3,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Appearance section (mimics macOS Settings > Appearance) -->
        <TextBlock Text="{loc:Loc Section_Appearance}" FontSize="15" FontWeight="SemiBold" Foreground="#1D1D1F" Margin="2,0,0,8" />
        <Border Background="White" CornerRadius="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.12" Color="#000000" />
            </Border.Effect>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="16,16">
                <!-- Light -->
                <StackPanel Margin="12,0">
                    <Border x:Name="LightSel" CornerRadius="11" BorderThickness="2" BorderBrush="Transparent"
                            Padding="3" Cursor="Hand" Tag="Light" MouseLeftButtonUp="AppearanceTile_Click">
                        <Border CornerRadius="8" ClipToBounds="True" Width="76" Height="48">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#5B8DEF" Offset="0" />
                                    <GradientStop Color="#9FC0FF" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <!-- Mini dock (light styling) -->
                            <Border VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,5"
                                    Width="44" Height="13" CornerRadius="5"
                                    Background="#66FFFFFF" BorderBrush="#33FFFFFF" BorderThickness="1">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border Width="6" Height="6" CornerRadius="1.5" Background="#5B8DEF" Margin="1.5,0" />
                                    <Border Width="6" Height="6" CornerRadius="1.5" Background="#34C759" Margin="1.5,0" />
                                    <Border Width="6" Height="6" CornerRadius="1.5" Background="#FF9F0A" Margin="1.5,0" />
                                    <Border Width="6" Height="6" CornerRadius="1.5" Background="#FF375F" Margin="1.5,0" />
                                </StackPanel>
                            </Border>
                        </Border>
                    </Border>
                    <RadioButton x:Name="LightRadio" GroupName="Appearance" Content="{loc:Loc Theme_Light}" Tag="Light"
                                 HorizontalAlignment="Center" Margin="0,7,0,0" FontSize="12"
                                 Foreground="#1D1D1F" Checked="AppearanceRadio_Checked" />
                </StackPanel>

                <!-- Dark -->
                <StackPanel Margin="12,0">
                    <Border x:Name="DarkSel" CornerRadius="11" BorderThickness="2" BorderBrush="Transparent"
                            Padding="3" Cursor="Hand" Tag="Dark" MouseLeftButtonUp="AppearanceTile_Click">
                        <Border CornerRadius="8" ClipToBounds="True" Width="76" Height="48">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#4B74C4" Offset="0" />
                                    <GradientStop Color="#829DD1" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <!-- Mini dock (dark styling) -->
                            <Border VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,5"
                                    Width="44" Height="13" CornerRadius="5"
                                    Background="#66242424" BorderBrush="#14FFFFFF" BorderThickness="1">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border Width="6" Height="6" CornerRadius="1.5" Background="#5B8DEF" Margin="1.5,0" />
                                    <Border Width="6" Height="6" CornerRadius="1.5" Background="#34C759" Margin="1.5,0" />
                                    <Border Width="6" Height="6" CornerRadius="1.5" Background="#FF9F0A" Margin="1.5,0" />
                                    <Border Width="6" Height="6" CornerRadius="1.5" Background="#FF375F" Margin="1.5,0" />
                                </StackPanel>
                            </Border>
                        </Border>
                    </Border>
                    <RadioButton x:Name="DarkRadio" GroupName="Appearance" Content="{loc:Loc Theme_Dark}" Tag="Dark"
                                 HorizontalAlignment="Center" Margin="0,7,0,0" FontSize="12"
                                 Foreground="#1D1D1F" Checked="AppearanceRadio_Checked" />
                </StackPanel>

                <!-- Auto (half light / half dark) -->
                <StackPanel Margin="12,0">
                    <Border x:Name="AutoSel" CornerRadius="11" BorderThickness="2" BorderBrush="Transparent"
                            Padding="3" Cursor="Hand" Tag="Auto" MouseLeftButtonUp="AppearanceTile_Click">
                        <Border CornerRadius="8" Width="76" Height="48">
                            <!-- Round the entire composite (both halves) as one shape, not each box. -->
                            <Border.Clip>
                                <RectangleGeometry Rect="0,0,76,48" RadiusX="8" RadiusY="8" />
                            </Border.Clip>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Rectangle Grid.Column="0">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#5B8DEF" Offset="0" />
                                            <GradientStop Color="#9FC0FF" Offset="1" />
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                                <Rectangle Grid.Column="1">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#4B74C4" Offset="0" />
                                            <GradientStop Color="#829DD1" Offset="1" />
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                                <!-- Mini dock spanning both halves: left = light styling, right = dark -->
                                <Border Grid.ColumnSpan="2" VerticalAlignment="Bottom" HorizontalAlignment="Center"
                                        Margin="0,0,0,5" Width="44" Height="13" CornerRadius="5"
                                        ClipToBounds="True" BorderThickness="1" BorderBrush="#26FFFFFF">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Rectangle Grid.Column="0" Fill="#66FFFFFF" />
                                        <Rectangle Grid.Column="1" Fill="#66242424" />
                                        <StackPanel Grid.ColumnSpan="2" Orientation="Horizontal"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Border Width="6" Height="6" CornerRadius="1.5" Background="#5B8DEF" Margin="1.5,0" />
                                            <Border Width="6" Height="6" CornerRadius="1.5" Background="#34C759" Margin="1.5,0" />
                                            <Border Width="6" Height="6" CornerRadius="1.5" Background="#FF9F0A" Margin="1.5,0" />
                                            <Border Width="6" Height="6" CornerRadius="1.5" Background="#FF375F" Margin="1.5,0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </Border>
                    <RadioButton x:Name="AutoRadio" GroupName="Appearance" Content="{loc:Loc Theme_Auto}" Tag="Auto"
                                 HorizontalAlignment="Center" Margin="0,7,0,0" FontSize="12"
                                 Foreground="#1D1D1F" Checked="AppearanceRadio_Checked" />
                </StackPanel>
            </StackPanel>
        </Border>

        <TextBlock Text="{loc:Loc Section_Dock}" FontSize="15" FontWeight="SemiBold" Foreground="#1D1D1F" Margin="2,18,0,8" />

        <!-- White grouped card -->
        <Border Background="White" CornerRadius="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.12" Color="#000000" />
            </Border.Effect>

            <StackPanel>
                <!-- Group 1: sliders -->
                <Grid Margin="16,16,16,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Size -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{loc:Loc Label_Size}" Style="{StaticResource GroupLabel}" Margin="0,0,0,6" />
                        <Slider x:Name="SizeSlider" Style="{StaticResource MacSlider}"
                                Minimum="12" Maximum="64" IsSnapToTickEnabled="True" TickFrequency="1"
                                ValueChanged="SizeSlider_ValueChanged" />
                        <Grid Margin="0,2,0,0">
                            <TextBlock Text="{loc:Loc Caption_Small}" Style="{StaticResource Caption}" HorizontalAlignment="Left" />
                            <TextBlock Text="{loc:Loc Caption_Large}" Style="{StaticResource Caption}" HorizontalAlignment="Right" />
                        </Grid>
                    </StackPanel>

                    <!-- Magnification -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{loc:Loc Label_Magnification}" Style="{StaticResource GroupLabel}" Margin="0,0,0,6" />
                        <Slider x:Name="MagnificationSlider" Style="{StaticResource MacSlider}"
                                Minimum="0" Maximum="9" IsSnapToTickEnabled="True" TickFrequency="1"
                                ValueChanged="MagnificationSlider_ValueChanged" />
                        <Grid Margin="0,2,0,0">
                            <TextBlock Text="{loc:Loc Caption_Off}" Style="{StaticResource Caption}" HorizontalAlignment="Left" />
                            <TextBlock Text="{loc:Loc Caption_Small}" Style="{StaticResource Caption}" HorizontalAlignment="Left" Margin="30,0,0,0" />
                            <TextBlock Text="{loc:Loc Caption_Large}" Style="{StaticResource Caption}" HorizontalAlignment="Right" />
                        </Grid>
                    </StackPanel>
                </Grid>

                <Border Height="1" Background="#E3E3E3" Margin="16,0,0,0" />

                <!-- Group 2: pop-up rows -->
                <Grid Height="44" Margin="16,0">
                    <TextBlock Text="{loc:Loc Row_Position}" Style="{StaticResource RowLabel}" HorizontalAlignment="Left" />
                    <ComboBox x:Name="PositionCombo" Style="{StaticResource MacPopup}" HorizontalAlignment="Right"
                              VerticalAlignment="Center" SelectionChanged="PositionCombo_SelectionChanged">
                        <ComboBoxItem Content="{loc:Loc Position_Bottom}" />
                        <ComboBoxItem Content="{loc:Loc Position_Left}" />
                        <ComboBoxItem Content="{loc:Loc Position_Right}" />
                        <ComboBoxItem Content="{loc:Loc Position_Top}" />
                    </ComboBox>
                </Grid>

                <Border Height="1" Background="#E3E3E3" Margin="16,0,0,0" />

                <Grid Height="44" Margin="16,0">
                    <TextBlock Text="{loc:Loc Row_GlassEffect}" Style="{StaticResource RowLabel}" HorizontalAlignment="Left" />
                    <ComboBox x:Name="GlassEffectCombo" Style="{StaticResource MacPopup}" HorizontalAlignment="Right"
                              VerticalAlignment="Center" SelectionChanged="GlassEffectCombo_SelectionChanged">
                        <ComboBoxItem Content="{loc:Loc Glass_Translucent}" />
                        <ComboBoxItem Content="{loc:Loc Glass_Acrylic}" />
                        <ComboBoxItem Content="{loc:Loc Glass_LiquidGlass}" />
                    </ComboBox>
                </Grid>

                <Border Height="1" Background="#E3E3E3" Margin="16,0,0,0" />

                <Grid Height="44" Margin="16,0">
                    <TextBlock Text="{loc:Loc Row_MinimizeUsing}" Style="{StaticResource RowLabel}" HorizontalAlignment="Left" />
                    <ComboBox x:Name="MinimizeCombo" Style="{StaticResource MacPopup}" HorizontalAlignment="Right"
                              VerticalAlignment="Center" SelectionChanged="MinimizeCombo_SelectionChanged">
                        <ComboBoxItem Content="{loc:Loc Minimize_Suck}" />
                        <ComboBoxItem Content="{loc:Loc Minimize_Scale}" />
                        <ComboBoxItem Content="{loc:Loc Minimize_Genie}" />
                    </ComboBox>
                </Grid>

                <Border Height="1" Background="#E3E3E3" Margin="16,0,0,0" />

                <!-- Effect speed: the slider matches the Magnification slider's width (same *,24,* grid). -->
                <Grid Margin="16,8,16,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{loc:Loc Label_EffectSpeed}" Style="{StaticResource RowLabel}"
                               VerticalAlignment="Center" HorizontalAlignment="Left" />
                    <StackPanel Grid.Column="2">
                        <!-- 5 snap positions: Slow, ·, Default, ·, Fast (ticks shown). -->
                        <Slider x:Name="EffectSpeedSlider" Style="{StaticResource MacSlider}"
                                Minimum="0" Maximum="4" IsSnapToTickEnabled="True" TickFrequency="1"
                                TickPlacement="BottomRight" ValueChanged="EffectSpeedSlider_ValueChanged" />
                        <Grid Margin="0,2,0,0">
                            <TextBlock Text="{loc:Loc Caption_Slow}" Style="{StaticResource Caption}" HorizontalAlignment="Left" />
                            <TextBlock Text="{loc:Loc Caption_Default}" Style="{StaticResource Caption}" HorizontalAlignment="Center" />
                            <TextBlock Text="{loc:Loc Caption_Fast}" Style="{StaticResource Caption}" HorizontalAlignment="Right" />
                        </Grid>
                    </StackPanel>
                </Grid>

                <Border Height="1" Background="#E3E3E3" Margin="16,0,0,0" />

                <!-- Group 3: toggle rows -->
                <Grid Height="44" Margin="16,0">
                    <TextBlock Text="{loc:Loc Toggle_ShowIndicators}" Style="{StaticResource RowLabel}" HorizontalAlignment="Left" />
                    <ToggleButton x:Name="IndicatorsSwitch" Style="{StaticResource MacSwitch}" HorizontalAlignment="Right"
                                  VerticalAlignment="Center" Click="IndicatorsSwitch_Click" />
                </Grid>

                <Border Height="1" Background="#E3E3E3" Margin="16,0,0,0" />

                <Grid Height="44" Margin="16,0">
                    <TextBlock Text="{loc:Loc Toggle_AnimateOpening}" Style="{StaticResource RowLabel}" HorizontalAlignment="Left" />
                    <ToggleButton x:Name="AnimateOpeningSwitch" Style="{StaticResource MacSwitch}" HorizontalAlignment="Right"
                                  VerticalAlignment="Center" Click="AnimateOpeningSwitch_Click" />
                </Grid>

                <Border Height="1" Background="#E3E3E3" Margin="16,0,0,0" />

                <Grid Height="44" Margin="16,0">
                    <TextBlock Text="{loc:Loc Toggle_MinimizeIntoIcon}" Style="{StaticResource RowLabel}" HorizontalAlignment="Left" />
                    <ToggleButton x:Name="MinimizeIntoIconSwitch" Style="{StaticResource MacSwitch}" HorizontalAlignment="Right"
                                  VerticalAlignment="Center" Click="MinimizeIntoIconSwitch_Click" />
                </Grid>

                <Border Height="1" Background="#E3E3E3" Margin="16,0,0,0" />

                <Grid Height="44" Margin="16,0">
                    <TextBlock Text="{loc:Loc Toggle_ShowMenuBar}" Style="{StaticResource RowLabel}" HorizontalAlignment="Left" />
                    <ToggleButton x:Name="ShowMenuBarSwitch" Style="{StaticResource MacSwitch}" HorizontalAlignment="Right"
                                  VerticalAlignment="Center" Click="ShowMenuBarSwitch_Click" />
                </Grid>

            </StackPanel>
        </Border>

        <!-- Taskbar section -->
        <TextBlock Text="{loc:Loc Section_Taskbar}" FontSize="15" FontWeight="SemiBold" Foreground="#1D1D1F" Margin="2,18,0,8" />
        <Border Background="White" CornerRadius="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.12" Color="#000000" />
            </Border.Effect>
            <Grid Height="44" Margin="16,0">
                <TextBlock Text="{loc:Loc Row_ShowTaskbar}" Style="{StaticResource RowLabel}" HorizontalAlignment="Left" />
                <ComboBox x:Name="TaskbarCombo" Style="{StaticResource MacPopup}" HorizontalAlignment="Right"
                          VerticalAlignment="Center" SelectionChanged="TaskbarCombo_SelectionChanged">
                    <ComboBoxItem Content="{loc:Loc Taskbar_Always}" />
                    <ComboBoxItem Content="{loc:Loc Taskbar_Auto}" />
                    <ComboBoxItem Content="{loc:Loc Taskbar_Never}" />
                </ComboBox>
            </Grid>
        </Border>
    </StackPanel>
    </ScrollViewer>
</Window>
