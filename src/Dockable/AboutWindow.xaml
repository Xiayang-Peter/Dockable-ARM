<Window x:Class="Dockable.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Dockable.Localization"
        Title="{loc:Loc Menu_AboutDockable}"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        SizeToContent="Height"
        Width="420"
        Background="#EDEDED"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Ideal"
        FontFamily="Segoe UI"
        Foreground="#1D1D1F">

    <StackPanel Margin="28,24,28,22">
        <!-- App icon -->
        <Image x:Name="AppImage" Width="96" Height="96" HorizontalAlignment="Center" />

        <!-- Name + tagline + version -->
        <TextBlock Text="Dockable" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center"
                   Margin="0,12,0,0" />
        <TextBlock Text="{loc:Loc About_Tagline}" FontSize="13" Foreground="#3A3A3C"
                   HorizontalAlignment="Center" TextAlignment="Center" Margin="0,4,0,0" />
        <TextBlock x:Name="VersionText" FontSize="12" Foreground="#6E6E73"
                   HorizontalAlignment="Center" Margin="0,4,0,0" />

        <!-- Description -->
        <Border Background="White" CornerRadius="10" Margin="0,18,0,0" Padding="16,14">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.12" Color="#000000" />
            </Border.Effect>
            <TextBlock Text="{loc:Loc About_Body}" FontSize="13" Foreground="#1D1D1F"
                       TextWrapping="Wrap" LineHeight="19" />
        </Border>

        <!-- Author credit -->
        <TextBlock HorizontalAlignment="Center" TextAlignment="Center" Margin="0,16,0,0"
                   FontSize="12" Foreground="#3A3A3C">
            <Run Text="{loc:Loc About_CreatedBy}" /><Run Text=" " /><Hyperlink
                NavigateUri="https://github.com/jezzlucena"
                RequestNavigate="Hyperlink_RequestNavigate">Jezz Lucena</Hyperlink>
        </TextBlock>

        <!-- Close -->
        <Button Content="{loc:Loc Common_Close}" HorizontalAlignment="Center" MinWidth="96"
                Padding="10,5" Margin="0,18,0,0" IsCancel="True" IsDefault="True"
                Click="Close_Click" />
    </StackPanel>
</Window>
