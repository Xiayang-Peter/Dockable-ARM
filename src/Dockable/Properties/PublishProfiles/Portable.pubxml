<?xml version="1.0" encoding="utf-8"?>
<!--
  Single portable executable: one self-contained Dockable.exe that runs on any Windows 11 x64 PC with
  nothing installed (the .NET 9 runtime + WPF are bundled inside).

  Self-contained + single-file, with the native libraries embedded and self-extracted, so the result is
  literally one .exe (no loose DLLs / .wav files alongside it). Compressed to keep the file smaller.
  NOT trimmed — WPF isn't trim-safe. ReadyToRun for a faster cold start.

  Publish:
    & "C:\Program Files\dotnet\dotnet.exe" publish "src\Dockable\Dockable.csproj" -p:PublishProfile=Portable
  Output:
    src\Dockable\bin\Publish\Portable\win-x64\Dockable.exe
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>x64</Platform>
    <PublishProtocol>FileSystem</PublishProtocol>
    <PublishDir>bin\Publish\Portable\win-x64\</PublishDir>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <!-- Embed native libs (WPF, hostfxr, …) into the exe and self-extract at startup → one file. -->
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <PublishReadyToRun>true</PublishReadyToRun>
    <PublishTrimmed>false</PublishTrimmed>
    <!-- No .pdb next to the portable exe. -->
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
  </PropertyGroup>
</Project>
