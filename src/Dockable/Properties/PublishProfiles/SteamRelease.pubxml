<?xml version="1.0" encoding="utf-8"?>
<!--
  Self-contained Release build for Steam distribution.

  Self-contained (no .NET runtime needed on the player's PC) + win-x64 + ReadyToRun (faster cold
  start). NOT single-file and NOT trimmed: WPF isn't trim-safe, and Steam ships a whole depot folder
  anyway, so a plain multi-file folder is the most robust thing to hand to SteamPipe — point the
  depot's ContentRoot at the PublishDir below.

  Publish:
    & "C:\Program Files\dotnet\dotnet.exe" publish "src\Dockable\Dockable.csproj" -p:PublishProfile=SteamRelease
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>x64</Platform>
    <PublishProtocol>FileSystem</PublishProtocol>
    <PublishDir>bin\Publish\Steam\win-x64\</PublishDir>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>false</PublishSingleFile>
    <PublishReadyToRun>true</PublishReadyToRun>
    <PublishTrimmed>false</PublishTrimmed>
    <!-- Keep the build lean: no .pdb in the shipped depot. -->
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
  </PropertyGroup>
</Project>
